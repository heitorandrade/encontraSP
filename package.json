{
  "name": "encontra-sp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"const fs=require('fs');['.next'].forEach((dir)=>fs.rmSync(dir,{recursive:true,force:true}));\"",
    "predev": "npm run clean",
    "prebuild": "npm run clean",
    "start:local": "powershell -ExecutionPolicy Bypass -File ./scripts/start-local.ps1",
    "dev": "next dev",
    "build": "next build",
    "preview": "npm run build && next start -p 3000",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "next": "^15.5.15",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.2",
    "@types/react-dom": "19.1.2",
    "autoprefixer": "10.4.21",
    "postcss": "8.5.3",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3"
  }
}
